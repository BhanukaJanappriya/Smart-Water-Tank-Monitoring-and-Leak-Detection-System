# Server Configuration
PORT=3000

# ESP32 IoT Device Configuration
# The ESP32 is running a web server at this address, exposing "/" which returns a JSON
ESP32_URL=http://watertank.local

# Polling Interval (in milliseconds) for background leak detection monitoring
POLL_INTERVAL_MS=10000

# Tank Dimensions & Calibration (for HC-SR04 ultrasonic sensor)
TANK_HEIGHT_CM=100
TANK_FULL_DISTANCE_CM=10
TANK_EMPTY_DISTANCE_CM=90
TANK_RADIUS_CM=30

# Leak Detection Settings
# Rate of continuous water level drop (cm/minute) during non-usage to flag as a leak
LEAK_THRESHOLD_CM_PER_MIN=0.1
